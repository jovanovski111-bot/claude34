{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Allow .js / .jsx files alongside .ts / .tsx — prevents
       TS18003 "No inputs found" on Vercel when JS files are present */
    "allowJs": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  /* All real source lives in src/. Listing it explicitly keeps
     root-level config / text files out of the TS compilation. */
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
